# WAQI Air Quality API — free token at https://aqicn.org/data-platform/token/
# Without a token, the app falls back to "demo" which only covers a few cities.
REACT_APP_WAQI_TOKEN=demo

# Supabase — get these from https://app.supabase.com → your project → Settings → API
# URL looks like: https://abcdefghijklmnop.supabase.co
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
# Anon key is safe to expose in the browser (row-level security controls access)
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# World Bank API is free and open — no key required.
# Leaving this here as a reminder that no auth is needed.
# Base URL: https://api.worldbank.org/v2/
